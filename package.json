{
  "name": "arta",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A live design canvas the AI writes into and the dev watches — driven by a single .arta/ folder.",
  "bin": {
    "arta": "bin/arta.mjs",
    "arta-mcp": "mcp/server.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && bun run build:mcp",
    "build:mcp": "bun build mcp/server.mjs --target=node --outfile mcp/server.bundle.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "mcp": "bun mcp/server.mjs",
    "eval:gate": "bun evals/gate.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.11.0",
    "lucide-react": "^0.469.0",
    "modern-screenshot": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
