{
  "meta": { "name": "Helix", "phase": "prototype" },
  "spec": {
    "goal": "Sell Helix — a single control plane that runs, routes, and observes every AI agent across every model and tool — to engineering teams in one scroll.",
    "users": ["Platform / AI engineers wiring agents into production", "Eng leads choosing an agent runtime", "On-call engineers debugging live agent runs"],
    "userStories": [
      "As a visitor, I want the hero to say exactly what Helix replaces (the glue between agent frameworks) so I know in five seconds if it's for me.",
      "As an engineer, I want to see the unified dashboard and the one-API story before I read pricing.",
      "As an eng lead, I want clear tiers and real customer proof so I can bring it to my team.",
      "As a skimmer, I want to click between Platform, Pricing and Customers without losing the thread."
    ],
    "scope": {
      "in": ["Marketing landing (Home)", "Platform deep-dive with interactive tabs", "Pricing with monthly/annual toggle", "Customers / proof"],
      "out": ["Real auth / signup", "Docs site", "Blog", "In-product app screens"]
    },
    "constraints": ["Terminal-native: near-black, monospace-forward (Geist Mono), one phosphor-green accent, CLI / command motifs", "One shared top bar + footer across screens", "Real CLI output as the hero, not a marketing template", "No gradient text, no hero-metric band, no identical card grids"]
  },
  "prototype": {
    "start": "home",
    "frame": "web",
    "store": { "billing": "monthly", "view": "run" },
    "tokens": {
      "fonts": [
        { "name": "body", "value": "'Geist', system-ui, sans-serif" },
        { "name": "mono", "value": "'Geist Mono', ui-monospace, monospace" }
      ],
      "colors": [
        { "name": "bg", "value": "#0a0b0d", "description": "terminal black, faintly cool" },
        { "name": "surface", "value": "#0f1316", "description": "terminal window fill" },
        { "name": "raised", "value": "#141a1e", "description": "insets / rows" },
        { "name": "border", "value": "#222a30", "description": "hairline / box rules" },
        { "name": "text", "value": "#d4dadf", "description": "soft phosphor white" },
        { "name": "heading", "value": "#eef2f0", "description": "bright ink — headings / emphasis on dark" },
        { "name": "lede", "value": "#aab4bb", "description": "secondary body — lede / descriptions on dark" },
        { "name": "dim", "value": "#7d8893", "description": "comments / secondary — ≥4.5:1" },
        { "name": "accent", "value": "#3ee08a", "description": "phosphor green — prompt, primary, success" },
        { "name": "accent-ink", "value": "#04140b", "description": "text on green" },
        { "name": "cyan", "value": "#5cc8ff", "description": "paths / links / secondary" },
        { "name": "amber", "value": "#f5b94a", "description": "warning / queued / highlight" },
        { "name": "rose", "value": "#ff6b6b", "description": "error / failed" }
      ],
      "typography": [
        { "name": "display", "sample": "the one command for every agent", "family": "'Geist Mono', monospace", "size": "clamp(1.7rem, 3.1vw, 2.5rem)", "weight": 500, "lineHeight": "1.18", "letterSpacing": "-0.02em" },
        { "name": "h2", "sample": "one runtime, three commands", "family": "'Geist Mono', monospace", "size": "clamp(1.25rem, 2.1vw, 1.7rem)", "weight": 500, "lineHeight": "1.25", "letterSpacing": "-0.01em" },
        { "name": "body", "sample": "Body prose set in Geist sans.", "family": "'Geist', sans-serif", "size": "0.95rem", "weight": 400, "lineHeight": "1.62" },
        { "name": "mono", "sample": "118ms · 18,402 tok · $0.21", "family": "'Geist Mono', monospace", "size": "0.8125rem", "weight": 450 },
        { "name": "label", "sample": "// agent control plane", "family": "'Geist Mono', monospace", "size": "0.6875rem", "weight": 500, "letterSpacing": "0.04em" }
      ],
      "spacing": [
        { "name": "xs", "value": "4px" }, { "name": "sm", "value": "8px" },
        { "name": "md", "value": "16px" }, { "name": "lg", "value": "28px" },
        { "name": "xl", "value": "48px" }, { "name": "2xl", "value": "80px" }
      ],
      "radii": [ { "name": "sm", "value": "5px" }, { "name": "md", "value": "7px" }, { "name": "lg", "value": "10px" }, { "name": "pill", "value": "999px" } ],
      "shadows": [
        { "name": "card", "value": "0 1px 0 rgba(255,255,255,.02) inset, 0 12px 36px -26px rgba(0,0,0,.85)" },
        { "name": "glow", "value": "0 0 0 1px rgba(62,224,138,.14), 0 30px 70px -34px rgba(62,224,138,.20)" }
      ]
    },
    "layout": "{{>topbar}}<main>{{slot}}</main>{{>footer}}",
    "components": { "topbar": "", "footer": "" },
    "screens": [
      { "id": "home", "title": "Home", "url": "helix.dev" },
      { "id": "platform", "title": "Platform", "url": "helix.dev/platform" },
      { "id": "pricing", "title": "Pricing", "url": "helix.dev/pricing" },
      { "id": "customers", "title": "Customers", "url": "helix.dev/customers" }
    ]
  },
  "dataModel": {
    "entities": [
      { "name": "Agent", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "defaultModel", "type": "string", "required": true },
        { "name": "policyId", "type": "uuid", "fk": "Policy" },
        { "name": "status", "type": "enum(active,paused)", "required": true }
      ] },
      { "name": "Run", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "agentId", "type": "uuid", "fk": "Agent", "required": true },
        { "name": "status", "type": "enum(queued,running,succeeded,failed)", "required": true },
        { "name": "model", "type": "string" },
        { "name": "tokens", "type": "int" },
        { "name": "costUsd", "type": "float" },
        { "name": "latencyMs", "type": "int" },
        { "name": "startedAt", "type": "timestamp", "required": true }
      ] },
      { "name": "Step", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "runId", "type": "uuid", "fk": "Run", "required": true },
        { "name": "kind", "type": "enum(model,tool,route)", "required": true },
        { "name": "name", "type": "string" },
        { "name": "durationMs", "type": "int" }
      ] },
      { "name": "Provider", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "kind", "type": "enum(model,tool,vectordb)" },
        { "name": "healthy", "type": "boolean" }
      ] },
      { "name": "Policy", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "maxCostUsd", "type": "float" },
        { "name": "rateLimitRpm", "type": "int" },
        { "name": "allowedModels", "type": "string[]" }
      ] }
    ],
    "relationships": [
      { "from": "Run", "to": "Agent", "type": "N:1", "label": "of" },
      { "from": "Step", "to": "Run", "type": "N:1", "label": "in" },
      { "from": "Agent", "to": "Policy", "type": "N:1", "label": "governed by" }
    ]
  },
  "api": {
    "info": { "title": "Helix API", "version": "1.0.0" },
    "servers": [ { "url": "https://api.helix.dev/v1" } ],
    "x-middleware": [
      { "name": "auth", "description": "Helix API key (Bearer)" },
      { "name": "policy", "description": "Enforce the agent's spend cap + rate limit + allowed models" }
    ],
    "paths": {
      "/runs": {
        "post": {
          "summary": "Start an agent run (routes across providers)",
          "x-middleware": ["auth", "policy"],
          "x-screens": ["platform"],
          "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["agent", "input"], "properties": { "agent": { "type": "string" }, "input": { "type": "string" }, "model": { "type": "string", "description": "optional override; otherwise the router picks" } } }, "example": { "agent": "support-triage", "input": "Refund request #4821" } } } },
          "responses": { "201": { "description": "Run created" }, "402": { "description": "Spend cap reached" } }
        }
      },
      "/runs/{id}": {
        "get": {
          "summary": "Get a run with its step trace",
          "x-middleware": ["auth"],
          "x-screens": ["platform"],
          "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } } ],
          "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
        }
      },
      "/providers": {
        "get": { "summary": "List providers + live health", "x-middleware": ["auth"], "x-screens": ["platform"], "responses": { "200": { "description": "OK" } } }
      },
      "/policies": {
        "post": { "summary": "Create a guardrail policy", "x-middleware": ["auth"], "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "maxCostUsd": { "type": "number" }, "rateLimitRpm": { "type": "integer" } } } } } }, "responses": { "201": { "description": "Created" } } }
      }
    }
  },
  "architecture": {
    "stack": ["Go router (edge)", "NATS (run queue)", "ClickHouse (runs/traces)", "Postgres (config)", "React/Vite dashboard"],
    "nodes": [
      { "id": "dash", "name": "Dashboard", "kind": "client", "tech": "React/Vite", "description": "What you're looking at" },
      { "id": "api", "name": "Helix API", "kind": "service", "tech": "Go", "description": "One endpoint for every agent run" },
      { "id": "router", "name": "Model router", "kind": "gateway", "tech": "Go", "description": "Picks/fails-over across providers; enforces policy" },
      { "id": "queue", "name": "Run queue", "kind": "queue", "tech": "NATS" },
      { "id": "providers", "name": "Model + tool providers", "kind": "external", "tech": "Anthropic · OpenAI · open models · tools" },
      { "id": "runs", "name": "Runs + traces", "kind": "datastore", "tech": "ClickHouse" },
      { "id": "cfg", "name": "Config + policies", "kind": "datastore", "tech": "Postgres" }
    ],
    "edges": [
      { "from": "dash", "to": "api", "protocol": "REST", "mode": "sync" },
      { "from": "api", "to": "router", "protocol": "gRPC", "mode": "sync" },
      { "from": "api", "to": "queue", "protocol": "NATS", "mode": "async" },
      { "from": "router", "to": "providers", "protocol": "HTTPS", "mode": "sync" },
      { "from": "router", "to": "cfg", "protocol": "SQL", "mode": "sync" },
      { "from": "api", "to": "runs", "protocol": "native", "mode": "async" },
      { "from": "dash", "to": "runs", "protocol": "REST", "mode": "sync" }
    ],
    "decisions": [
      { "id": "ADR-1", "title": "One API, router decides the model", "status": "accepted", "context": "Teams glue together 3+ SDKs and hard-code model names, then can't fail over.", "options": ["Per-provider SDKs", "One Helix API + router", "Proxy only"], "decision": "Single /runs endpoint; the router selects the provider and fails over under policy.", "consequences": "Adds ~120ms routing overhead; needs live provider health in the dashboard." }
    ],
    "nfrs": [
      { "name": "Routing overhead", "target": "< 130ms median", "note": "p50, excludes model time" },
      { "name": "Uptime", "target": "99.99%", "note": "API + router" }
    ],
    "security": [ { "boundary": "customer → API", "note": "Bearer API key, per-policy rate limit + spend cap, full audit log" } ]
  },
  "plan": {
    "stack": ["Go", "NATS", "ClickHouse", "Postgres", "React/Vite"],
    "statuses": [
      { "id": "backlog", "name": "Backlog", "color": "#71717a" },
      { "id": "doing", "name": "In progress", "color": "#2563eb" },
      { "id": "review", "name": "Review", "color": "#fbbf24" },
      { "id": "done", "name": "Done", "color": "#34d399" }
    ],
    "milestones": [
      { "name": "M1 · Unified runs", "tasks": [
        { "title": "Single /runs endpoint", "status": "done", "priority": "high" },
        { "title": "Model router + failover", "status": "review", "priority": "high" },
        { "title": "Live provider health", "status": "doing", "priority": "high" }
      ] },
      { "name": "M2 · Observe", "tasks": [
        { "title": "Step trace waterfall", "status": "doing", "priority": "high" },
        { "title": "Token + cost per step", "status": "backlog", "priority": "normal" },
        { "title": "Replay a run", "status": "backlog", "priority": "normal" }
      ] },
      { "name": "M3 · Govern", "tasks": [
        { "title": "Spend-cap policies", "status": "backlog", "priority": "high" },
        { "title": "Audit log export", "status": "backlog", "priority": "low" }
      ] }
    ]
  }
}
