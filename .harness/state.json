{
  "meta": { "name": "Gateway Monitor", "phase": "prototype" },
  "spec": {
    "goal": "Give an operator a single live screen to read an edge gateway's health — traffic, cache, latency and errors — in one glance.",
    "users": ["Platform / edge operator", "On-call engineer", "Performance engineer"],
    "userStories": [
      "As an operator, I want live throughput, egress and cache-hit at the top so I know the gateway's state instantly.",
      "As an engineer, I want a tailing request stream with status + cache decision so I can spot a bad pattern as it happens.",
      "As a performance engineer, I want latency distribution and cache outcomes so I can see where time and misses go."
    ],
    "scope": {
      "in": ["Live traffic + egress charts", "Top endpoints", "Tailing request stream", "Latency histogram", "Status + cache breakdown"],
      "out": ["Config editing", "Per-tenant billing", "Historical (>1h) analytics"]
    },
    "constraints": ["Single screen, no scroll on 1440p", "1s live refresh / tailing stream", "Light theme, mono numerics, log-scale latency"]
  },
  "prototype": {
    "start": "overview",
    "frame": "web",
    "store": {},
    "tokens": {
      "fonts": [
        { "name": "body", "value": "'Geist', system-ui, sans-serif" },
        { "name": "mono", "value": "'Geist Mono', ui-monospace, monospace" }
      ],
      "colors": [
        { "name": "bg", "value": "#eef1f4", "description": "page" },
        { "name": "surface", "value": "#ffffff", "description": "cards" },
        { "name": "border", "value": "#e4e8ee", "description": "hairline" },
        { "name": "ink", "value": "#1f2733", "description": "primary text" },
        { "name": "dim", "value": "#7a828f", "description": "labels / secondary" },
        { "name": "green", "value": "#16a34a", "description": "primary · healthy · 2xx · HIT" },
        { "name": "blue", "value": "#2563eb", "description": "egress · 3xx · dynamic" },
        { "name": "amber", "value": "#e0820c", "description": "bypass · slow" },
        { "name": "red", "value": "#dc2626", "description": "errors · blocked" }
      ],
      "typography": [
        { "name": "kpi", "sample": "56,112", "family": "'Geist', sans-serif", "size": "1.9rem", "weight": 650, "lineHeight": "1", "letterSpacing": "-0.01em" },
        { "name": "body", "family": "'Geist', sans-serif", "size": "0.875rem", "weight": 400, "lineHeight": "1.5" },
        { "name": "mono", "family": "'Geist Mono', monospace", "size": "0.8125rem", "weight": 500 },
        { "name": "label", "sample": "CACHE HIT RATIO", "family": "'Geist Mono', monospace", "size": "0.65rem", "weight": 500, "letterSpacing": "0.07em" }
      ],
      "spacing": [
        { "name": "xs", "value": "4px" }, { "name": "sm", "value": "8px" },
        { "name": "md", "value": "14px" }, { "name": "lg", "value": "24px" }, { "name": "xl", "value": "40px" }
      ],
      "radii": [ { "name": "sm", "value": "5px" }, { "name": "md", "value": "10px" }, { "name": "lg", "value": "14px" } ],
      "shadows": [ { "name": "card", "value": "0 1px 2px rgba(16,24,40,.04)" } ]
    },
    "layout": "{{>topbar}}<div class=\"dash\">{{slot}}</div>",
    "screens": [
      { "id": "overview", "title": "Overview", "url": "gateway.edge/overview" },
      { "id": "requests", "title": "Requests", "url": "gateway.edge/requests" },
      { "id": "cache", "title": "Cache", "url": "gateway.edge/cache" },
      { "id": "routes", "title": "Routes", "url": "gateway.edge/routes" }
    ]
  },
  "dataModel": {
    "entities": [
      { "name": "Route", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "method", "type": "enum(GET,POST,OPTIONS)", "required": true },
        { "name": "path", "type": "string", "required": true },
        { "name": "cachePolicy", "type": "enum(cacheable,bypass,dynamic)" }
      ] },
      { "name": "RequestSample", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "routeId", "type": "uuid", "fk": "Route", "required": true },
        { "name": "status", "type": "int", "required": true },
        { "name": "cacheDecision", "type": "enum(HIT_T1,HIT_T2,BYPASS,MISS)" },
        { "name": "durationMs", "type": "float" },
        { "name": "ts", "type": "timestamp", "required": true }
      ] },
      { "name": "Upstream", "fields": [
        { "name": "id", "type": "uuid", "pk": true },
        { "name": "host", "type": "string", "required": true },
        { "name": "rttMs", "type": "float" },
        { "name": "connReusePct", "type": "float" }
      ] }
    ],
    "relationships": [
      { "from": "RequestSample", "to": "Route", "type": "N:1", "label": "for" },
      { "from": "Route", "to": "Upstream", "type": "N:1", "label": "proxies to" }
    ]
  },
  "api": {
    "info": { "title": "Gateway Admin API", "version": "1.0.0" },
    "servers": [ { "url": "https://edge.acme.dev/admin/v1" } ],
    "x-middleware": [ { "name": "auth", "description": "Admin bearer token" } ],
    "paths": {
      "/stats": {
        "get": { "summary": "Aggregate stats (rolling window)", "x-middleware": ["auth"], "x-screens": ["gateway"],
          "parameters": [ { "name": "window", "in": "query", "schema": { "type": "string" }, "description": "60s | 5m | 1h" } ],
          "responses": { "200": { "description": "OK" } } }
      },
      "/stream": {
        "get": { "summary": "Tailing request stream (SSE)", "x-middleware": ["auth"], "x-screens": ["gateway"],
          "responses": { "200": { "description": "text/event-stream of request samples" } } }
      },
      "/cache/purge": {
        "post": { "summary": "Purge a cache key/prefix", "x-middleware": ["auth"],
          "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["prefix"], "properties": { "prefix": { "type": "string" } } } } } },
          "responses": { "202": { "description": "Accepted" } } }
      }
    }
  },
  "architecture": {
    "stack": ["Rust edge proxy", "DragonflyDB (T2 cache)", "in-proc LRU (T1)", "ClickHouse (samples)", "React dashboard"],
    "nodes": [
      { "id": "client", "name": "Clients", "kind": "external", "tech": "Browsers / apps" },
      { "id": "edge", "name": "Edge gateway", "kind": "gateway", "tech": "Rust", "description": "TLS, routing, T1 mem cache, rate-limit" },
      { "id": "t2", "name": "T2 cache", "kind": "cache", "tech": "DragonflyDB" },
      { "id": "origin", "name": "Origin services", "kind": "service", "tech": "Upstream APIs" },
      { "id": "samples", "name": "Samples store", "kind": "datastore", "tech": "ClickHouse" },
      { "id": "dash", "name": "Monitor", "kind": "client", "tech": "React/Vite" }
    ],
    "edges": [
      { "from": "client", "to": "edge", "protocol": "HTTPS", "mode": "sync" },
      { "from": "edge", "to": "t2", "protocol": "RESP", "mode": "sync" },
      { "from": "edge", "to": "origin", "protocol": "HTTP", "mode": "sync" },
      { "from": "edge", "to": "samples", "protocol": "native", "mode": "async" },
      { "from": "dash", "to": "samples", "protocol": "REST", "mode": "sync" }
    ],
    "decisions": [
      { "id": "ADR-1", "title": "Two-tier cache (mem T1 + DragonflyDB T2)", "status": "accepted", "context": "Hit ratio target >95% with low memory per edge node.", "options": ["mem only", "mem + DragonflyDB", "mem + Redis"], "decision": "T1 in-proc LRU for hot keys, T2 DragonflyDB shared across nodes.", "consequences": "Two lookups on T1 miss; needs T2 health in the cache-decision breakdown." }
    ],
    "nfrs": [
      { "name": "Cache hit ratio", "target": "> 95%", "note": "T1+T2 combined" },
      { "name": "p99 latency", "target": "< 30ms", "note": "edge-terminated" }
    ],
    "security": [ { "boundary": "client → edge", "note": "TLS, per-tenant rate limit, tenant header required (else edge_blocked)" } ]
  },
  "plan": {
    "stack": ["Rust", "DragonflyDB", "ClickHouse", "React/Vite"],
    "statuses": [
      { "id": "backlog", "name": "Backlog", "color": "#94a3b8" },
      { "id": "doing", "name": "In progress", "color": "#2563eb" },
      { "id": "review", "name": "Review", "color": "#e0820c" },
      { "id": "done", "name": "Done", "color": "#16a34a" }
    ],
    "milestones": [
      { "name": "M1 · Live monitor", "tasks": [
        { "title": "KPI header + sparklines", "status": "done", "priority": "high" },
        { "title": "Throughput + egress charts", "status": "review", "priority": "high" },
        { "title": "Tailing request stream (SSE)", "status": "doing", "priority": "high" }
      ] },
      { "name": "M2 · Cache insight", "tasks": [
        { "title": "Cache decision breakdown", "status": "doing", "priority": "normal" },
        { "title": "One-click purge", "status": "backlog", "priority": "normal" }
      ] }
    ]
  }
}
