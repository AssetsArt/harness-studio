{
  "meta": {
    "name": "Aurora Store",
    "phase": "prototype"
  },
  "spec": {
    "goal": "Help a first-time shopper find a product and reach checkout in under two minutes.",
    "users": [
      "Shopper",
      "Returning customer",
      "Merchant"
    ],
    "userStories": [
      "As a shopper, I want to browse featured products on the home page so I can find something fast.",
      "As a shopper, I want to add to cart without leaving the page so I keep browsing.",
      "As a returning customer, I want my cart to persist while I look around the store."
    ],
    "scope": {
      "in": [
        "Storefront",
        "Product detail",
        "Cart"
      ],
      "out": [
        "Payments",
        "Shipping rates",
        "Reviews"
      ]
    },
    "constraints": [
      "Mobile-first, responsive",
      "Guest checkout — no account required",
      "Mock catalog only — no real inventory"
    ]
  },
  "plan": {
    "stack": [
      "React",
      "Next.js",
      "Stripe",
      "Tailwind"
    ],
    "milestones": [
      {
        "name": "M1 · Storefront",
        "tasks": [
          {
            "title": "Design system + tokens",
            "status": "done"
          },
          {
            "title": "Home + product grid",
            "status": "doing"
          },
          {
            "title": "Product detail",
            "status": "todo"
          },
          {
            "title": "Cart drawer",
            "status": "todo"
          }
        ]
      },
      {
        "name": "M2 · Checkout",
        "tasks": [
          {
            "title": "Stripe session",
            "status": "todo"
          },
          {
            "title": "Order confirmation",
            "status": "todo"
          }
        ]
      }
    ]
  },
  "dataModel": {
    "entities": [
      {
        "name": "Product",
        "fields": [
          {
            "name": "id",
            "type": "uuid",
            "pk": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "price",
            "type": "int",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "image",
            "type": "string"
          }
        ]
      },
      {
        "name": "CartItem",
        "fields": [
          {
            "name": "id",
            "type": "uuid",
            "pk": true
          },
          {
            "name": "productId",
            "type": "uuid",
            "fk": "Product",
            "required": true
          },
          {
            "name": "qty",
            "type": "int",
            "required": true
          }
        ]
      },
      {
        "name": "Order",
        "fields": [
          {
            "name": "id",
            "type": "uuid",
            "pk": true
          },
          {
            "name": "customerId",
            "type": "uuid",
            "fk": "Customer",
            "required": true
          },
          {
            "name": "total",
            "type": "int",
            "required": true
          },
          {
            "name": "status",
            "type": "enum",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "timestamp",
            "required": true
          }
        ]
      },
      {
        "name": "Customer",
        "fields": [
          {
            "name": "id",
            "type": "uuid",
            "pk": true
          },
          {
            "name": "email",
            "type": "string",
            "required": true
          }
        ]
      }
    ],
    "relationships": [
      {
        "from": "CartItem",
        "to": "Product",
        "type": "N:1",
        "label": "of"
      },
      {
        "from": "Order",
        "to": "Customer",
        "type": "N:1",
        "label": "by"
      }
    ]
  },
  "flow": {
    "nodes": [
      {
        "id": "s_home",
        "kind": "screen",
        "label": "Home"
      },
      {
        "id": "s_product",
        "kind": "screen",
        "label": "Product"
      },
      {
        "id": "s_cart",
        "kind": "screen",
        "label": "Cart"
      },
      {
        "id": "a_products",
        "kind": "api",
        "label": "GET /products"
      },
      {
        "id": "a_cart",
        "kind": "api",
        "label": "POST /cart"
      },
      {
        "id": "e_product",
        "kind": "entity",
        "label": "Product"
      },
      {
        "id": "e_cart",
        "kind": "entity",
        "label": "CartItem"
      }
    ],
    "edges": [
      {
        "from": "s_home",
        "to": "a_products",
        "label": "list",
        "op": "read"
      },
      {
        "from": "a_products",
        "to": "e_product",
        "op": "read"
      },
      {
        "from": "s_product",
        "to": "a_cart",
        "label": "add to cart",
        "op": "write"
      },
      {
        "from": "a_cart",
        "to": "e_cart",
        "op": "write"
      },
      {
        "from": "s_cart",
        "to": "e_cart",
        "label": "read bag",
        "op": "read"
      }
    ]
  },
  "prototype": {
    "start": "home",
    "store": {
      "cart": 0
    },
    "vars": {
      "brand": "Aurora",
      "logo": "A"
    },
    "layout": "{{>header}}{{slot}}{{>footer}}",
    "screens": [
      {
        "id": "home",
        "title": "Home",
        "url": "aurora.shop"
      },
      {
        "id": "product",
        "title": "Product detail",
        "url": "aurora.shop/p/oak-serving-tray"
      },
      {
        "id": "cart",
        "title": "Cart",
        "url": "aurora.shop/cart"
      }
    ]
  },
  "api": {
    "info": {
      "title": "Aurora Store API",
      "version": "1.0.0",
      "description": "Storefront + queue endpoints"
    },
    "servers": [
      {
        "url": "https://api.aurora.shop/v1"
      }
    ],
    "x-middleware": [
      {
        "name": "cors",
        "description": "Allow cross-origin requests from the storefront"
      },
      {
        "name": "auth",
        "description": "Require a valid Bearer token"
      },
      {
        "name": "rateLimit",
        "description": "60 requests/min per IP"
      }
    ],
    "paths": {
      "/products": {
        "get": {
          "summary": "List products",
          "tags": [
            "Products"
          ],
          "x-middleware": [
            "cors",
            "rateLimit"
          ],
          "parameters": [
            {
              "name": "page",
              "in": "query",
              "required": false,
              "schema": {
                "type": "integer",
                "format": "int32"
              },
              "example": 1,
              "description": "Page number"
            },
            {
              "name": "limit",
              "in": "query",
              "required": false,
              "schema": {
                "type": "integer"
              },
              "example": 20
            },
            {
              "name": "q",
              "in": "query",
              "required": false,
              "schema": {
                "type": "string"
              },
              "description": "Search term"
            }
          ],
          "responses": {
            "200": {
              "description": "A page of products",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "title": {
                          "type": "string"
                        },
                        "price": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "example": [
                    {
                      "id": "p_01",
                      "title": "Aurora Mug",
                      "price": 19
                    }
                  ]
                }
              }
            }
          }
        },
        "post": {
          "summary": "Create a product",
          "tags": [
            "Products"
          ],
          "x-middleware": [
            "cors",
            "auth"
          ],
          "parameters": [
            {
              "name": "Authorization",
              "in": "header",
              "required": true,
              "schema": {
                "type": "string"
              },
              "description": "Bearer <token>"
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "title",
                    "price"
                  ],
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "price": {
                      "type": "number"
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "example": {
                  "title": "New Item",
                  "price": 25
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Created"
            },
            "400": {
              "description": "Validation error"
            },
            "401": {
              "description": "Unauthorized"
            }
          }
        }
      },
      "/products/{id}": {
        "get": {
          "summary": "Get a product",
          "tags": [
            "Products"
          ],
          "x-middleware": [
            "cors",
            "rateLimit"
          ],
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              },
              "description": "Product id"
            }
          ],
          "responses": {
            "200": {
              "description": "OK",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "404": {
              "description": "Not found"
            }
          }
        }
      },
      "/queue/walk-in": {
        "post": {
          "summary": "Add a walk-in to the queue",
          "tags": [
            "Queue"
          ],
          "x-middleware": [
            "cors",
            "auth"
          ],
          "parameters": [
            {
              "name": "Authorization",
              "in": "header",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "name",
                    "size"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "size": {
                      "type": "integer"
                    },
                    "phone": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "name": "พี่บอส",
                  "size": 4,
                  "phone": "081-234-5678"
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Queued",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "ticket": {
                        "type": "string"
                      },
                      "eta": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
